{
  "profile_support": {
    "profiles": "hooks/profiles.json",
    "runtime_env": ["VEX_HOOK_PROFILE", "VEX_DISABLED_HOOKS"],
    "cli": ["python tools/vex_hooks.py profile set <name>", "python tools/vex_hooks.py disable <hook-name>"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "name": "check-file-size",
            "profiles": ["minimal", "standard", "strict"],
            "command": "python hooks/scripts/check-file-size.py",
            "description": "Block oversized generated files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "name": "validate-frontmatter",
            "profiles": ["standard", "strict"],
            "command": "python hooks/scripts/validate-frontmatter.py",
            "description": "Validate markdown frontmatter after edits"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "name": "post-tool-use",
            "profiles": ["standard", "strict"],
            "command": "python hooks/scripts/post-tool-use.py",
            "description": "Log VEX tool usage metadata"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "stop",
            "profiles": ["standard", "strict"],
            "command": "python hooks/scripts/stop.py",
            "description": "Summarize VEX session status"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "name": "session-start",
            "profiles": ["standard", "strict"],
            "command": "python hooks/scripts/session-start.py",
            "description": "Show VEX toolkit context"
          }
        ]
      }
    ]
  }
}
