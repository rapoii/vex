  "description": "VEX — Vareva ECC Extended. 100% free, MIT-licensed agent harness system for Claude Code.",
  "main": "index.js",
  "scripts": {
    "install:vex": "bash install.sh --profile full",
    "install:dev": "bash install.sh --profile developer",
    "install:minimal": "bash install.sh --profile minimal",
